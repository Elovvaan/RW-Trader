# SAIN-FLIGHTS Propulsion Controller — environment variables
#
# Copy this file to .env and adjust values before running.
# All variables are optional; defaults are shown.

# ── Field Mode ────────────────────────────────────────────────────────────────
# Enable Version-1 tangential-field control (4-node geometry).
# When "false" (default) the legacy setThrottle(avgLift) path is used.
FIELD_MODE_ENABLED=false

# Phase advance in radians per second.
# Default: 2π ≈ 6.2832 rad/s (one full rotation per second).
FIELD_PHASE_VELOCITY=6.283185307179586

# Spin direction: "1" = CCW (default), "-1" = CW.
FIELD_SPIN=1

# Output scaling — applied after the field solver, before dispatch.
# FIELD_OUTPUT_SCALE multiplies each per-motor value.
# FIELD_OUTPUT_MIN / MAX clamp the result.
# Defaults are identity (scale=1.0, min=0.0, max=1.0).
FIELD_OUTPUT_SCALE=1.0
FIELD_OUTPUT_MIN=0.0
FIELD_OUTPUT_MAX=1.0

# ── MAVLink Bridge ────────────────────────────────────────────────────────────
# UDP host/port of the autopilot (SITL or real hardware).
MAVLINK_HOST=127.0.0.1
MAVLINK_PORT=14550

# This GCS system id and component id sent in outgoing MAVLink frames.
MAVLINK_SYSID=255
MAVLINK_COMPID=190

# Target vehicle system id and component id.
MAVLINK_TARGET_SYSID=1
MAVLINK_TARGET_COMPID=1

# Milliseconds to wait for COMMAND_ACK before falling back to
# SET_ACTUATOR_CONTROL_TARGET.
MAVLINK_ACK_TIMEOUT=2000

# ── Runtime adapter selection ─────────────────────────────────────────────────
# "sim"      — SimAdapter (logs to stdout, no hardware)
# "hardware" — MavlinkAdapter + MavlinkBridgeImpl (real / SITL)
RUNTIME=sim
